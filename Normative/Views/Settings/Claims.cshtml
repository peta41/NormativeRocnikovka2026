@*@model IEnumerable<System.Security.Claims.Claim>*@
@model Normative.Models.Screen.Settings.ModelClaims
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = "Claims";
}

<!-- Header -->
@await Html.PartialAsync("_Header", Model.Navigation)
<!-- End Header -->
<!-- Toolbar -->
@await Html.PartialAsync("_Toolbar", Model.ToolBar)
<!-- End Toolbar -->

<div class="container pt-3">
    <main role="main" class="pt-2 pb-3">
        <div class="container py-3 pt-5">
            <div class="row pt-3 ps-2 pe-2">

@*                 <div class="py-1"></div>
                
                <nav class="breadcrumbs">
                    <a asp-controller="Home" asp-action="Index" class="breadcrumbs_item">@Localizer["Home"]</a>
                    <a asp-controller="Settings" asp-action="Index" class="breadcrumbs_item">@Localizer["Settings"]</a>
                    <a asp-controller="Settings" asp-action="Claims" class="breadcrumbs_item is-active">@Localizer["Claims"]</a>
                </nav>

                <div class="py-3"></div> *@

                <table class="table table-striped table-hover border border-1">
                    <tr>
                        <th>Type</th>
                        <th>Value</th>
                    </tr>

                    @foreach (var claim in Model.Claims.OrderBy(x => x.Type))
                    {
                        <tr>
                            <td>@claim.Type</td>
                            <td>@claim.Value</td>
                        </tr>
                    }
                </table>
            </div>
        </div>
        @* @await Html.PartialAsync("_SidePanel", Model.Navigation) *@
    </main>
</div>
