@model ModelViewUser
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["Settings"];
}

<!-- Header -->
@await Html.PartialAsync("_Header", Model.Navigation)
<!-- End Header -->
<!-- Toolbar -->
@await Html.PartialAsync("_Toolbar", Model.ModelToolBar)
<!-- End Toolbar -->

<style>
    .Edit-Button-Users {
        text-decoration: none;
        color: black;
    }
</style>


<main role="main" class="pb-3">
    <div class=""> @* py-3 *@
        <h4 style="font-weight: bold;"><i class="icon icon-people"></i>@Localizer["Users"]</h4>
        <hr />

        <table class="table table-striped table-bordered border border-1 mb-3">
            <thead>
                <tr>
                    <th class="col-3">@Localizer["Display Name"]</th>
                    <th class="col-3">@Localizer["UserName"]</th>
                    <th class="col-3">@Localizer["Role"]</th>
                    <th class="col-3">@Localizer["Email"]</th>
                    <th colspan="3" class="text-end"></th>
                </tr>
            </thead>

            <tbody class="scrollable-table-body">
                @foreach (ViewUsersRoles u in Model.Users)
                {
                    <tr>
                        <td class="col-3">@u.DisplayName</td>
                        <td class="col-3">@u.UserName</td>
                        <td class="col-3">@u.Role</td>
                        <td class="col-3">@u.Email</td>
                        <td colspan="3" class="text-end">
                            <button class="btn btn-outline-primary">
                                <a class="Edit-Button-Users"
                                   asp-controller="user"
                                   asp-action="Edit"
                                   asp-route-id="@u.UserId">
                                    @Localizer["Edit"]
                                </a>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="row">
            <div class="col-10">
                @Html.PagedListPager(
                         Model.Users,
                         page => Url.Action("Users", new
                         {
                             page = page
                         }),
                         new PagedListRenderOptions()
                {
                    LiElementClasses = new List<string> { "page-item page-item" },
                    UlElementClasses = new List<string> { "pagination" },
                    PageClasses = new string[] { "page-link" },
                    MaximumPageNumbersToDisplay = 5,
                }
                         )
            </div>

            <div class="col-2 text-end">
                @(Model.Users.PageCount < Model.Users.PageNumber ? 0 : Model.Users.PageNumber) @Localizer["of"] @Model.Users.PageCount
            </div>
        </div>
    </div>
</main>