@model OperationModel

@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Header -->
@await Html.PartialAsync("_Header", Model.Navigation)
<!-- End Header -->
<!-- Toolbar -->
@await Html.PartialAsync("_Toolbar", Model.ToolBar)
<!-- End Toolbar -->

<style>
    .Back-Button-OperationsCn {
        text-decoration: none;
        color: black;
    }

    .ProductLineId-adjust-Cn-Operations {
        margin-bottom: 5px;
    }

    .ProductTypeId-adjust-Cn-Operations {
        margin-bottom: 5px;
    }

    .OperationNumber-adjust-Cn-Operations {
        margin-bottom: 5px;
    }

    .OperationDescription-adjust-Cn-Operations {
        margin-bottom: 5px;
    }

    .WorkCenter-adjust-Cn-Operations {
        margin-bottom: 5px;
    }

    .Create-adjust-Cn-Operations {
        margin-bottom: 5px;
    }
</style>

<h1>@Localizer["Create"]</h1>

<h4>@Localizer["Operation"]</h4>
<hr />
<div class="container d-flex justify-content-center mt-5">
    <div class="row w-75">
        <form asp-action="Create" class="row">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group col-md-6">
                <label asp-for="@Model.Operation.ProductLineId" class="control-label"></label>
                <select asp-for="@Model.Operation.ProductLineId" class="form-control ProductLineId-adjust-Cn-Operations" asp-items="ViewBag.ProductLineId"></select>
            </div>
            <div class="form-group col-md-6">
                <label asp-for="@Model.Operation.ProductTypeId" class="control-label"></label>
                <select asp-for="@Model.Operation.ProductTypeId" class="form-control ProductTypeId-adjust-Cn-Operations" asp-items="ViewBag.ProductTypeId"></select>
            </div>
            <div class="form-group col-md-6">
                <label asp-for="@Model.Operation.OperationNumber" class="control-label"></label>
                <input asp-for="@Model.Operation.OperationNumber" class="form-control OperationNumber-adjust-Cn-Operations" />
                <span asp-validation-for="@Model.Operation.OperationNumber" class="text-danger"></span>
            </div>
            <div class="form-group col-md-6">
                <label asp-for="@Model.Operation.OperationDescription" class="control-label"></label>
                <input asp-for="@Model.Operation.OperationDescription" class="form-control OperationDescription-adjust-Cn-Operations" />
                <span asp-validation-for="@Model.Operation.OperationDescription" class="text-danger"></span>
            </div>
            <div class="form-group col-md-6">
                <label asp-for="@Model.Operation.WorkCenter" class="control-label"></label>
                <input asp-for="@Model.Operation.WorkCenter" class="form-control WorkCenter-adjust-Cn-Operations" />
                <span asp-validation-for="@Model.Operation.WorkCenter" class="text-danger"></span>
            </div>
        </form>
    </div>
</div>



@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
