@model OperationModel

@{
    ViewData["Title"] = "Delete";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Header -->
@await Html.PartialAsync("_Header", Model.Navigation)
<!-- End Header -->
<!-- Toolbar -->
@await Html.PartialAsync("_Toolbar", Model.ToolBar)
<!-- End Toolbar -->

<h1>@Localizer["Delete"]</h1>

<h3>@Localizer["Are you sure you want to delete this?"]</h3>
<div>
    <h4>@Localizer["Operation"]</h4>
    <hr />
    <table class="table table-striped table-bordered table-sm">
        <tr>
            <th>@Localizer["ColunName"]</th>
            <th>@Localizer["ColunData"]</th>
        </tr>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Operation.OperationNumber)</th>
            <td>@Html.DisplayFor(model => model.Operation.OperationNumber)</td>
        </tr>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Operation.OperationDescription)</th>
            <td>@Html.DisplayFor(model => model.Operation.OperationDescription)</td>
        </tr>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Operation.WorkCenter)</th>
            <td>@Html.DisplayFor(model => model.Operation.WorkCenter)</td>
        </tr>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Operation.ProductLine)</th>
            <td>@Html.DisplayFor(model => model.Operation.ProductLine.ProductLineId)</td>
        </tr>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Operation.ProductType)</th>
            <td>@Html.DisplayFor(model => model.Operation.ProductType.ProductTypeId)</td>
        </tr>
    </table>
    
    <form asp-action="Delete" method="post" class="needs-validation" id="myform">
        <input type="hidden" asp-for="@Model.Operation.OperationId" />
        @* <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a> *@
    </form>
</div>

@section Scripts {

    <script src="/js/form.js"></script>

}