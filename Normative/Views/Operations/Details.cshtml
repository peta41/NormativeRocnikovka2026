@model OperationModel

@{
    ViewData["Title"] = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Header -->
@await Html.PartialAsync("_Header", Model.Navigation)
<!-- End Header -->
<!-- Toolbar -->
@await Html.PartialAsync("_Toolbar", Model.ToolBar)
<!-- End Toolbar -->

<style>
    .Operations-Det-tab {
        /* width: 300px; */
        width:1296px;
        margin-bottom: 5px;
    }

    .Col-Name-Det-Operations {
        font-weight: bold;
    }

    .Edit-Button-OperationsDet {
        text-decoration: none;
        color: black;
    }

    .Back-Button-OperationsDet {
        text-decoration: none;
        color: black;
    }
</style>

<h1>@Localizer["Details"]</h1>
 
<div>
    <h4>@Localizer["Operation"]</h4>
    <hr />
    <table class="table table-striped table-bordered table-sm Operations-Det-tab">
        <tr>
            <th>@Localizer["ColumnName"]</th>
            <th>@Localizer["ColumnData"]</th>
        </tr>
        <tr>
            <td class="Col-Name-Det-Operations">@Html.DisplayNameFor(model => model.Operation.ProductLine.Name)</td>
            <td>@Html.DisplayFor(model => model.Operation.ProductLine.Name)</td>
        </tr>
        <tr>
            <td class="Col-Name-Det-Operations">@Html.DisplayNameFor(model => model.Operation.ProductType.Name)</td>
            <td>@Html.DisplayFor(model => model.Operation.ProductType.Name)</td>
        </tr>
        <tr>
            <td class="Col-Name-Det-Operations">@Html.DisplayNameFor(model => model.Operation.OperationNumber)</td>
            <td>@Html.DisplayFor(model => model.Operation.OperationNumber)</td>
        </tr>
        <tr>
            <td class="Col-Name-Det-Operations">@Html.DisplayNameFor(model => model.Operation.OperationDescription)</td>
            <td>@Html.DisplayFor(model => model.Operation.OperationDescription)</td>
        </tr>
        <tr>
            <td class="Col-Name-Det-Operations">@Html.DisplayNameFor(model => model.Operation.WorkCenter)</td>
            <td>@Html.DisplayFor(model => model.Operation.WorkCenter)</td>
        </tr>
    </table>
</div>
