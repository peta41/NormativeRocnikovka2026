@model OutherVessel

@{
    ViewData["Title"] = "Home Page";
}

<!-- Header -->
@await Html.PartialAsync("_Header", Model.Navigation)
<!-- End Header -->
<!-- Toolbar -->
@await Html.PartialAsync("_Toolbar", Model.ToolBar)
<!-- End Toolbar -->

<ul class="nav nav-tabs" id="myTab" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="home-tab" data-bs-toggle="tab" data-bs-target="#home-tab-pane" type="button" role="tab" aria-controls="home-tab-pane" aria-selected="true">@Localizer["OP10"]</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="profile-tab" data-bs-toggle="tab" data-bs-target="#profile-tab-pane" type="button" role="tab" aria-controls="profile-tab-pane" aria-selected="false">@Localizer["OP20"]</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="contact-tab" data-bs-toggle="tab" data-bs-target="#contact-tab-pane" type="button" role="tab" aria-controls="contact-tab-pane" aria-selected="false">@Localizer["OP40"]</button>
    </li>
</ul>
<div class="tab-content" id="myTabContent">
    <div class="tab-pane fade show active" id="home-tab-pane" role="tabpanel" aria-labelledby="home-tab" tabindex="0">
        <table class="table table-striped table-bordered table-sm">
            <thead>
                <tr>
                    <th style="text-align:center">@Localizer["ORDER"]</th>
                    <th style="text-align:center">@Localizer["OPERATION"]</th>
                    <th colspan="4" style="text-align:center">@Localizer["PRODUCT LINES(OPERATION TIMES)"]</th>
                    <th style="text-align:center">@Localizer["OPTIONS"]</th>
                </tr>
            </thead>

            <tr>
                <td></td>
                <td class="fw-bold" style="text-align:center">OP.10</td>
                <td class="fw-bold" style="text-align:center">D1800</td>
                <td class="fw-bold" style="text-align:center">D2100</td>
                <td class="fw-bold" style="text-align:center">D2500</td>
                <td class="fw-bold" style="text-align:center">D3000</td>
                <td class="fw-bold" style="text-align:center">@Localizer["OPTION X"]</td>
            </tr>
            @foreach (V_VTC_OutherVessel_OPSQ_10 row in Model.Op10)
            {
                <tr>
                    <td class="fw-bold" style="text-align:center">@row.Sequence</td>
                    <td class="fw-bold">@row.NameOperationStep</td>
                    <td><button type="button" class="btn btn-outline-primary w-100 me-1" data-bs-toggle="button" data-part-col="A1" data-value="@row.D1800" aria-pressed="false">@row.D1800</button></td>
                    <td><button type="button" class="btn btn-outline-primary w-100 me-1" data-bs-toggle="button" data-part-col="A2" data-value="@row.D2100" aria-pressed="false">@row.D2100</button></td>
                    <td><button type="button" class="btn btn-outline-primary w-100 me-1" data-bs-toggle="button" data-part-col="A3" data-value="@row.D2500" aria-pressed="false">@row.D2500</button></td>
                    <td><button type="button" class="btn btn-outline-primary w-100 me-1" data-bs-toggle="button" data-part-col="A4" data-value="@row.D3000" aria-pressed="false">@row.D3000</button></td>
                    <td class="fw-bold" style="text-align:center">@row.Option</td>
                </tr>
            }
            <tr>
                <td class="fw-bold" colspan="2" style="text-align:center">CELKEM</td>
                <td class="fw-bold" style="text-align:center"><span id="A1totalValue">0</span></td>
                <td class="fw-bold" style="text-align:center"><span id="A2totalValue">0</span></td>
                <td class="fw-bold" style="text-align:center"><span id="A3totalValue">0</span></td>
                <td class="fw-bold" style="text-align:center"><span id="A4totalValue">0</span></td>
                <td></td>
            </tr>     
        </table>
    </div>
    
   

