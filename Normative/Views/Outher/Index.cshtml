    @section Scripts {


        <script> //upravit
            $(function () {
                // if any button is clicked
                $("button[data-value]").on("click", function () {

                    var A1total = 0;
                    var A2total = 0
                    var A3total = 0;
                    var A4total = 0;
                    //sekce2
                    var B1total = 0;
                    var B2total = 0
                    var B3total = 0;
                    var B4total = 0;
                    //sekce3
                    var C1total = 0;
                    var C2total = 0
                    var C3total = 0;
                    var C4total = 0;


                    // take only selected button
                    $("button[data-value][aria-pressed='true']").each(function () {
                        let partCol = $(this).attr("data-part-col");
                        let value = parseFloat($(this).attr("data-value"));

                        switch (partCol) {
                            //sekce1
                            case "A1":
                                A1total += value;
                                break;
                            case "A2":
                                A2total += value;
                                break;
                            case "A3":
                                A3total += value;
                                break;
                            case "A4":
                                A4total += value;
                                break;
                            //sekce2
                            case "B1":
                                B1total += value;
                                break;
                            case "B2":
                                B2total += value;
                                break;
                            case "B3":
                                B3total += value;
                                break;
                            case "B4":
                                B4total += value;
                                break;
                            //sekce3
                            case "C1":
                                C1total += value;
                                break;
                            case "C2":
                                C2total += value;
                                break;
                            case "C3":
                                C3total += value;
                                break;
                            case "C4":
                                C4total += value;
                                break;
                        }
                    });
                    //sekce1
                    $("#A1totalValue").text(A1total);
                    $("#A2totalValue").text(A2total);
                    $("#A3totalValue").text(A3total);
                    $("#A4totalValue").text(A4total);
                    //sekce2
                    $("#B1totalValue").text(B1total);
                    $("#B2totalValue").text(B2total);
                    $("#B3totalValue").text(B3total);
                    $("#B4totalValue").text(B4total);
                    //sekce3
                    $("#C1totalValue").text(C1total);
                    $("#C2totalValue").text(C2total);
                    $("#C3totalValue").text(C3total);
                    $("#C4totalValue").text(C4total);
                });

                //select column function
                // $('button[data-part-col]').on('click', function () {
                //     var selectedDataCol = $(this).attr('data-part-col');

                //     //disable columns
                //     $('[data-part-col]').each(function () {
                //         var col = $(this).attr('data-part-col');
                //         if (col !== selectedDataCol) {
                //             $(this).prop('disabled', true);
                //         } else {
                //             $(this).prop('disabled', false);
                //         }
                //     });
                // });

                $('button[data-part-col]').on('click', function () {
                    const selectedDataCol = $(this).attr('data-part-col');
                    $(this).toggleClass('selected');

                    const anySelected = $('button.selected').length > 0;

                    if (anySelected) {
                        const activeCol = $('button.selected').first().attr('data-part-col');

                        $('[data-part-col]').each(function () {
                            const col = $(this).attr('data-part-col');
                            $(this).prop('disabled', col !== activeCol);
                        });

                        const buttonsInCol = $(`button[data-part-col="${activeCol}"]`);
                        const selectedInCol = buttonsInCol.filter('.selected');

                        if (selectedInCol.length === 0) {
                            $('[data-part-col]').prop('disabled', false);
                        }
                    } else {
                        $('[data-part-col]').prop('disabled', false);
                    }
                });



            });
        </script>
    }

    
