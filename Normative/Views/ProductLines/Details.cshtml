@model ProductLineModel

@{
    ViewData["Title"] = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Header -->
@await Html.PartialAsync("_Header", Model.Navigation)
<!-- End Header -->
<!-- Toolbar -->
@await Html.PartialAsync("_Toolbar", Model.ToolBar)
<!-- End Toolbar -->

<style>
    .ProdLine-Det-tab{
        /* width: 300px; */
        width:1296px;
        margin-bottom: 5px;
    }

    .Col-Name-Det-ProdLine {
        font-weight: bold;
    }

    .Edit-Button-ProductLineDet {
        text-decoration: none;
        color: black;
    }

    .Back-Button-ProductLineDet{
        text-decoration: none;
        color: black;
    }
</style>

<h1>@Localizer["Details"]</h1>

<div>
    <h4>@Localizer["ProductLine"]</h4>
    <hr />
    <table class="table table-striped table-bordered table-sm ProdLine-Det-tab">
        <tr>
            <th>@Localizer["ColumnName"]</th>
            <th>@Localizer["Data"]</th>
        </tr>
        <tr>
            <td class="Col-Name-Det-ProdLine">@Html.DisplayNameFor(model => model.ProductLine.Name)</td>
            <td>@Html.DisplayFor(model => model.ProductLine.Name)</td>
        </tr>
    </table>
</div>
