@* @model IEnumerable<Normative.Models.Settings.ProductType> *@
@model ProductTypeModel

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Header -->
@await Html.PartialAsync("_Header", Model.Navigation)
<!-- End Header -->
<!-- Toolbar -->
@await Html.PartialAsync("_Toolbar", Model.ToolBar)
<!-- End Toolbar -->

<style>
    .Create-Button-ProductTypes {
        text-decoration: none;
        color: black;
    }

    .Edit-Button-ProductTypes {
        text-decoration: none;
        color: black;
    }

    .Details-Button-ProductTypes {
        text-decoration: none;
        color: black;
    }

    .Delete-Button-ProductTypes {
        text-decoration: none;
        color: black;
    }

</style>

@* <h1>@Localizer["Index"]</h1>
 *@
<h4 style="font-weight: bold;">@Localizer["ProductType"]</h4>
<hr />
@* <p>
    <button class="btn btn-outline-secondary w-10 me-1"><a class="Create-Button-ProductTypes" asp-action="Create">Create New</a></button>
</p> *@
<table class="table table-striped table-bordered table-sm Prod-Types-tab">
    <thead>
        <tr>
            <th>@Localizer["Name"]</th>
            <th class="options-size">@* @Localizer["Options"] *@</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.ProductTypes) {
        <tr>
            <td class="col-9">
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td colspan="3" class="text-end">
                    <button class="btn btn-outline-primary"><a class="Edit-Button-ProductTypes" asp-action="Edit" asp-route-id="@item.ProductTypeId">@Localizer["Edit"]</a></button>
                    <button class="btn btn-outline-primary"><a class="Details-Button-ProductTypes" asp-action="Details" asp-route-id="@item.ProductTypeId">@Localizer["Details"]</a></button>
                    <button class="btn btn-outline-danger"><a class="Delete-Button-ProductTypes" asp-action="Delete" asp-route-id="@item.ProductTypeId">@Localizer["Delete"]</a></button>
            </td>
        </tr>
}
    </tbody>
</table>



<div class="row">
    <div class="col-10">
        @Html.PagedListPager(
                 Model.ProductTypes,
                 page => Url.Action("Index", new
                 {
                     page = page
                 }),
                 new PagedListRenderOptions()
        {
            LiElementClasses = new List<string> { "page-item page-item" },
            UlElementClasses = new List<string> { "pagination" },
            PageClasses = new string[] { "page-link" },
            MaximumPageNumbersToDisplay = 5,
        })

    </div>
    <div class="col-2 text-end">
        @(Model.ProductTypes.PageCount < Model.ProductTypes.PageNumber ? 0 : Model.ProductTypes.PageNumber) z @Model.ProductTypes.PageCount
    </div>
</div>
