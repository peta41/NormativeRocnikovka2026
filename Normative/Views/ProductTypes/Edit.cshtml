@model ProductTypeModel

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Header -->
@await Html.PartialAsync("_Header", Model.Navigation)
<!-- End Header -->
<!-- Toolbar -->
@await Html.PartialAsync("_Toolbar", Model.ToolBar)
<!-- End Toolbar -->

<style>
    .Back-Button-ProductTypeE {
        text-decoration: none;
        color: black;
    }

    .Name-adjust-E-Type {
        margin-bottom: 5px;
    }

    .Save-adjust-E-Type {
        margin-bottom: 5px;
    }
</style>

<h1>@Localizer["Edit"]</h1>

<h4>@Localizer["ProductType"]</h4>
<hr />
<div class="container d-flex mt-5">
    <div class="row w-75">
        <form asp-action="Edit" class="row" id="myform">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" name="ProductTypeId" value="@Model.ProductType.ProductTypeId" />
            <label for="ProductTypeId">@Localizer["Product Type"]</label>
            <div class="form-group col-md-6">
                <input asp-for="@Model.ProductType.Name" class="form-control Name-adjust-E-Type" />
            </div>
        </form>
    </div>
</div>


@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <script>
        function Save() {
            $('#myform').submit(); // jQuery .submit() trigger validaci spustí
        }
    </script>
}
