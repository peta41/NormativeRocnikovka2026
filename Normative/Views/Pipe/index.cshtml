    @section Scripts {


    <script>

        //scitani sloupcu
        //upravit
        $(function () {
            // if any button is clicked
            $("button").on("click", function () {
                recalculate();
            });



            //new call
            $("tr[data-identity]").find("button").on("click", function () {
                var e = $(this)
                console.log(e);

                var iden = e.closest("tr").data("identity");
                var isPressed = e.attr('aria-pressed');
                var datacol = e.attr("data-part-col");
                var numberPattern = /\d+/g;
                var colNumber = datacol.match(numberPattern);


                console.log(iden);

                $.each($("tr[data-identity='" + iden + "']").find("button[data-part-col*=" + colNumber + "]"), function (key, value) {

                    var e1 = $(this);
                    console.log(isPressed);
                    //var newState = !isPressed;

                    e1.attr('aria-pressed', isPressed);

                    console.log('isPressed', isPressed);

                    if (isPressed == 'true') {
                        e1.addClass('selected active');
                    } else {
                        e1.removeClass('selected active');
                    }

                });
            });


            // propojeni operaci 20 a 30
            $("button[data-target-column]").on("click", function () {

                let column = $(this).attr("data-target-column");
                var e = $(this).closest("tr").find("button");

                // čištění při změně velikosti
                e.attr("aria-pressed", false).removeClass("active");
                $("button[data-column]").addClass("disabled");

                //  aktivate potřebného sloupce
                $("button[data-column=" + column + "]").removeClass("disabled active selected");

                // aktivace stejného tlačítka v jiné operaci
                var b = $("button[data-target-column]");
                var datacol = $(this).attr("data-part-col");
                console.log(datacol)

                // aktivuj toto tlačítko
                $("button[data-part-col").attr("aria-pressed", false).removeClass("active");
                $("button[data-part-col='" + datacol + "']").attr("aria-pressed", true).addClass("active");

                GetPreparation($(this).attr("data-size"));

                /* CHLADICI SMYCKA */
                // set chladici smycka
                $("#tdp1").html($(this).attr("data-diameter"));
                $("#tdp2").html($(this).attr("data-size"));

                $(".diameter-cell").addClass("d-none");
                $("." + $(this).attr("data-diameter")).removeClass("d-none");
                $('#ZvolenaVelikostSmycka').text("0").attr('data-value', "0");
                /* END CHLADICI SMYCKA */
            });



            // show input behind button
            $("#flexSwitchCheckDefault").on("change", function () {
                if (this.checked) {
                    $("button[data-part-col]").addClass("d-none");
                    $("input[data-part-col]").removeClass("d-none");
                } else {
                    $("button[data-part-col]").removeClass("d-none");
                    $("input[data-part-col]").addClass("d-none");
                }
                recalculate();
            });


            $("input[data-part-col]").on("change", function () {
                let e = $(this);

                let v = e.val();
                let s = e.attr("data-uniq");
                $("button[data-uniq=" + s + "]").attr("data-value", v).text(v);

            });

            //recalculate
            function recalculate() {
                var A1total = 0;
                var A2total = 0
                var A3total = 0;
                var A4total = 0;
                var A5total = 0;
                var A6total = 0;
                var A7total = 0;
                var A8total = 0;
                var A9total = 0;
                //sekce2
                var B1total = 0;
                var B2total = 0
                var B3total = 0;
                var B4total = 0;
                var B5total = 0;
                var B6total = 0;
                var B7total = 0;
                var B8total = 0;
                var B9total = 0;


                // pouzite prumery
                var arrDiameter = [];
                $("#p15").text('0'); // TODO: dodelat ostatni prumery
                $("#p21").text('0');
                $("#p33").text('0');
                $("#p48").text('0');
                $("#p60").text('0');
                $("#other").text('0');
                // end pouzite prumery

                // take only selected button
                $("button[data-value][aria-pressed='true']").each(function () {
                    let partCol = $(this).attr("data-part-col");
                    let value = parseFloat($(this).attr("data-value"));

                    // pouzite prumery
                    let diam = $(this).attr("data-pipe-diameter");
                    if (diam != null) {
                        arrDiameter.push(diam);
                    }
                    // end pouzite prumery

                    switch (partCol) {
                        //sekce1
                        case "A1":
                            A1total += value;
                            break;
