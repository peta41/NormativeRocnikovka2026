            //pocet ohybu v tabulce ohybani
            function updateCombinedValue() {
                let ohybyValue = parseFloat($('#ohybyMeziTotalVal').attr('data-value')) || 0;
                let outputValue = 0;
                let RadioKryt = $('input:radio[name=KrytVyv]:checked');
                outputValue = ohybyValue + (parseFloat(RadioKryt.attr("data-bending-value") || 0));
                console.log("recalculate", ohybyValue, outputValue);
                $('#PocetOhybuVOhybech').attr('data-value', outputValue).text(outputValue);
            }

            //vybirani sloupcu
            let myinputs = $('.ohybyMezi, .objimkyMezi');
            myinputs.on('change', function () {
                RecalculateBendingWelding();
                updateCombinedValue();
                updateObjimkyValues();
            });

            //pri zmene inputu se prepocita mezi tabulka
            function RecalculateBendingWelding() {
                var c1 = 0;
                var c2 = 0;

                $.each(myinputs, function (index, element) {

                    if (!isNaN(parseFloat(element.value))) {
                        if (index % 2 === 0) {
                            c1 += parseFloat(element.value);
                        } else {
                            c2 += parseFloat(element.value);
                        }
                    }
                });
                //vypis/aktualizace vypoctu
                $("#objimkyTotalVal").text(c1).attr("data-value", c1);
                $("#ohybyMeziTotalVal").text(c2).attr("data-value", c2);
            }

