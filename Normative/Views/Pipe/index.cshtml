@model PipeModel

@{
    ViewData["Title"] = "Home Page";
}

<!-- Header -->
@await Html.PartialAsync("_Header", Model.Navigation)
<!-- End Header -->
<!-- Toolbar -->
@await Html.PartialAsync("_Toolbar", Model.ToolBar)
<!-- End Toolbar -->

<style>
    .dropdown-menu li {
        position: relative;
    }

    .dropdown-menu .dropdown-submenu {
        display: none;
        position: absolute;
        left: 100%;
        top: -7px;
    }

    .dropdown-menu .dropdown-submenu-left {
        right: 100%;
        left: auto;
    }

    .dropdown-menu > li:hover > .dropdown-submenu {
        display: block;
    }

    .disabled{
        pointer-events: none;
        opacity: 0.5;
    }

    /* 270dg rotate */
    .rotate-270 {
        transform: rotate(270deg);
        position: absolute;
        top: 20px;
    }

    .rotate-header {
        height: 50px;
    }

    .reset-button{
        /* width: 150px; */
        width: auto;
    }

</style>



@* switch for editing values *@ @* switching between button and input *@

   <div class="d-flex justify-content-end">
      <div class="form-check form-switch">
