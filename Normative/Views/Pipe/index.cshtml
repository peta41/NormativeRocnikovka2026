            //objimky pocitani
            function calculateTotal(className, outputId) {
                let total = 0;
                $('td.' + className).each(function () {
                    let value = parseFloat($(this).find('input').attr('data-value')) || 0;
                    total += value;
                });
                $('#' + outputId).attr('data-value', total);
                $('#' + outputId).text(total);
            }

            calculateTotal('objimkyMezi', 'objimkyTotalVal');
            calculateTotal('ohybyMezi', 'ohybyMeziTotalVal');

            $('td.objimkyMezi input').on('input', function () {
