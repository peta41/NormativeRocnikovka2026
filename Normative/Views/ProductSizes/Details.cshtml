@model PreparationsModel

@{
    ViewData["Title"] = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Header -->
@await Html.PartialAsync("_Header", Model.Navigation)
<!-- End Header -->
<!-- Toolbar -->
@await Html.PartialAsync("_Toolbar", Model.ToolBar)
<!-- End Toolbar -->

<style>
    .ProdSize-Det-tab {
        /* width: 300px; */
        width:1296px;
        margin-bottom: 5px;
    }

    .Col-Name-Det-ProdSize {
        font-weight: bold;
    }

    .Edit-Button-ProductSizeDet {
        text-decoration: none;
        color: black;
    }

    .Back-Button-ProductSizeDet {
        text-decoration: none;
        color: black;
    }
</style>

<h1>@Localizer["Details"]</h1>

<div>
    <h4>@Localizer["ProductSize"]</h4>
    <hr />
    <table class="table table-striped table-bordered table-sm ProdSize-Det-tab">
        <tr>
            <th>@Localizer["ColumnName"]</th>
            <th>@Localizer["ColumnData"]</th>
        </tr>
        <tr>
            <td class="Col-Name-Det-ProdSize">@Html.DisplayNameFor(model => model.ProductSize.Name)</td>
            <td>@Html.DisplayFor(model => model.ProductSize.Name)</td>
        </tr>
        <tr>
            <td class="Col-Name-Det-ProdSize">@Html.DisplayNameFor(model => model.ProductSize.Size)</td>
            <td>@Html.DisplayFor(model => model.ProductSize.Size)</td>
        </tr>
    </table>
</div>
