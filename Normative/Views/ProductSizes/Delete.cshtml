@model PreparationsModel

@{
    ViewData["Title"] = "Delete";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Header -->
@await Html.PartialAsync("_Header", Model.Navigation)
<!-- End Header -->
<!-- Toolbar -->
@await Html.PartialAsync("_Toolbar", Model.ToolBar)
<!-- End Toolbar -->

<h1>@Localizer["Delete"]</h1>

<h3>@Localizer["Are you sure you want to delete this?"]</h3>
<div>
    <h4>@Localizer["ProductSize"]</h4>
    <hr />
    <table class="table table-striped table-bordered table-sm">
        <tr>
            <th>@Localizer["ColumnName"]</th>
            <th>@Localizer["ColumnData"]</th>
        </tr>
        <tr>
            <th>@Html.DisplayNameFor(model => model.ProductSize.Name)</th>
            <td>@Html.DisplayFor(model => model.ProductSize.Name)</td>
        </tr>
        <tr>
            <th>@Html.DisplayNameFor(model => model.ProductSize.Size)</th>
            <td>@Html.DisplayFor(model => model.ProductSize.Size)</td>
        </tr>
    </table>
    
    <form asp-action="Delete" method="post" class="needs-validation" id="myform">
        <input type="hidden" asp-for="@Model.ProductSize.ProductSizeId" />
        <input type="submit" value="Delete" class="btn btn-danger d-none" /> 
    </form>
</div>


@section Scripts {

    <script src="/js/form.js"></script>
    
}